// ===========================================
// SOC - Prisma Schema
// Contrat de données complet du monolithe
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// UTILISATEURS
// ===========================================

enum SubscriptionTier {
  FREE
  PREMIUM
  ULTRA
}

enum ProfileVisibility {
  PUBLIC
  PRIVATE
}

model User {
  id                String            @id @default(uuid())
  email             String            @unique
  passwordHash      String
  displayName       String            @default("")
  profileVisibility ProfileVisibility @default(PRIVATE)
  subscriptionTier  SubscriptionTier  @default(FREE)
  avatarUrl         String?

  // Profil (utilisé par le site vitrine)
  firstName String @default("")
  lastName  String @default("")
  phone     String @default("")
  address   String @default("")

  // Limites Freemium
  dailyCommentCount Int @default(0)
  dailyCommentReset DateTime @default(now())

  // Quotas IA mensuels
  aiMessageCount    Int      @default(0)
  aiMessageResetAt  DateTime @default(now())

  // Réputation sociale
  adviceScore    Int   @default(0)
  adviceVotes    Int   @default(0)
  reputationScore Float @default(0)

  // Paramètres
  darkMode Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  dolls              Doll[]
  appointments       Appointment[]
  orders             Order[]
  socialComments     SocialComment[]
  socialLikes        SocialLike[]
  sentAdviceVotes    AdviceVote[]      @relation("VoterAdvice")
  receivedAdviceVotes AdviceVote[]     @relation("ReceiverAdvice")

  @@map("users")
}

// ===========================================
// DOLLS (Entité Critique)
// ===========================================

enum DollGender {
  FEMME
  HOMME
  AUTRE
}

enum BodyMaterial {
  SILICONE
  TPE
  HYBRID
}

enum HeadMaterial {
  SILICONE
  TPE
  VINYL
}

enum SkinCondition {
  IDEALE
  BONNE
  USURE_LEGERE
  DEGRADEE
  CRITIQUE
}

enum JointCondition {
  NEUVE
  BONNE
  LEGERE_FISSURE
  USEE
  CASSEE
}

enum MaintenanceStage {
  OPTIMAL
  SECHAGE_RECOMMANDE
  HUMIDITE_STAGNANTE
  POUDRAGE_NECESSAIRE
  PROLIFERATION_BACTERIENNE
  FRAGILISATION_STRUCTURE
  INTERVENTION_URGENTE
}

model Doll {
  id        String   @id @default(uuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Identification
  fullName        String
  brand           String?
  gender          DollGender   @default(FEMME)
  acquisitionDate DateTime     @default(now())

  // Apparence
  skinTone    String?   // "Claire", "Naturelle", "Bronzée", "Mate", "Foncée", "Ébène"
  eyeColor    String?   // "Bleu", "Vert", "Marron", "Noisette", "Gris", "Noir"
  hairColor   String?   // "Blond", "Brun", "Noir", "Roux", "Blanc", "Rose"...
  hairLength  String?   // "Court", "Mi-long", "Long", "Très long"
  hairStyle   String?   // "Lisse", "Ondulé", "Bouclé", "Frisé"

  // Specs physiques
  bodyMaterial BodyMaterial @default(TPE)
  headMaterial HeadMaterial @default(TPE)
  sizeCm       Float?
  weightKg     Float?
  bustSize     Float?    // cm tour de poitrine
  waistSize    Float?    // cm tour de taille
  hipSize      Float?    // cm tour de hanches
  footSize     Float?    // pointure

  // Notes / caractéristiques spéciales
  features     String?

  // Photos
  photos    DollPhoto[]

  // Garde-robe virtuelle
  wardrobe  WardrobeItem[]

  // === MAINTENANCE (Axe I) ===
  lastWashedAt      DateTime?
  skinCondition     SkinCondition    @default(IDEALE)
  jointCondition    JointCondition   @default(NEUVE)
  fissureCount      Int              @default(0)
  maintenanceStage  MaintenanceStage @default(OPTIMAL)
  degradationLevel  Int              @default(0)  // 0-100
  statusMessage     String           @default("Tout est en ordre.")

  // Premium
  isPremiumAsset Boolean @default(false)

  // Social
  viewCount  Int @default(0)
  likeCount  Int @default(0)
  shareCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  maintenanceHistory MaintenanceRecord[]
  issues             DollIssue[]
  appointments       Appointment[]
  socialComments     SocialComment[]
  socialLikes        SocialLike[]

  @@index([ownerId])
  @@map("dolls")
}

model DollPhoto {
  id     String @id @default(uuid())
  dollId String
  doll   Doll   @relation(fields: [dollId], references: [id], onDelete: Cascade)
  url    String
  caption String?
  sortOrder Int @default(0)
  createdAt DateTime @default(now())

  @@index([dollId])
  @@map("doll_photos")
}

model WardrobeItem {
  id         String   @id @default(uuid())
  dollId     String
  doll       Doll     @relation(fields: [dollId], references: [id], onDelete: Cascade)
  name       String
  category   String?  // "Robe", "Top", "Bas", "Lingerie", "Chaussures", "Accessoire", "Ensemble"
  color      String?  // "Noir", "Blanc", "Rouge", "Bleu"...
  material   String?  // "Coton", "Soie", "Dentelle", "Cuir", "Synthétique"...
  length     String?  // "Courte", "Mi-longue", "Longue"
  brand      String?  // Marque du vêtement
  notes      String?  // Détails personnalisés
  imageUrl   String?
  acquiredAt DateTime @default(now())

  @@index([dollId])
  @@map("wardrobe_items")
}

// ===========================================
// MAINTENANCE & ENTRETIEN (Axe I)
// ===========================================

enum MaintenanceAction {
  LAVAGE
  POUDRAGE
  SECHAGE
  REPARATION_ARTICULATION
  REPARATION_PEAU
  CONTROLE_ETAT
  DESINFECTION
  MAQUILLAGE
  COIFFURE
  HYDRATATION_TPE
  NETTOYAGE_ORIFICES
  SERRAGE_ARTICULATIONS
  PREPARATION_STOCKAGE
  TRAITEMENT_TACHES
  AUTRE
}

model MaintenanceRecord {
  id       String            @id @default(uuid())
  dollId   String
  doll     Doll              @relation(fields: [dollId], references: [id], onDelete: Cascade)
  action   MaintenanceAction
  notes    String?
  performedBy String?        // "owner" ou "technician:{id}"
  performedAt DateTime       @default(now())

  // Snapshot de l'état après maintenance
  degradationAfter Int?
  stageAfter       MaintenanceStage?

  @@index([dollId])
  @@index([performedAt])
  @@map("maintenance_records")
}

// ===========================================
// RENDEZ-VOUS & SERVICES (Logistique)
// ===========================================

enum AppointmentType {
  NETTOYAGE
  POUDRAGE
  CONTROLE_ETAT
  REPARATION
  GARDIENNAGE
}

enum AppointmentStatus {
  DEMANDE
  CONFIRME
  EN_COURS
  TERMINE
  ANNULE
}

model Appointment {
  id        String            @id @default(uuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  dollId    String
  doll      Doll              @relation(fields: [dollId], references: [id], onDelete: Cascade)

  type      AppointmentType
  status    AppointmentStatus @default(DEMANDE)

  scheduledAt DateTime
  address     String?
  notes       String?

  // Gardiennage
  isStorageService Boolean  @default(false)
  storageStartAt   DateTime?
  storageEndAt     DateTime?

  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([dollId])
  @@index([scheduledAt])
  @@map("appointments")
}

// ===========================================
// E-COMMERCE (Axe II)
// ===========================================

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  currency    String   @default("EUR")
  imageUrl    String?
  category    String   // "nettoyage", "poudrage", "reparation", "accessoire"
  inStock     Boolean  @default(true)
  stockQty    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]

  @@map("products")
}

enum OrderStatus {
  EN_ATTENTE
  PAYEE
  EXPEDIEE
  LIVREE
  ANNULEE
  REMBOURSEE
}

model Order {
  id       String      @id @default(uuid())
  userId   String?
  user     User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status   OrderStatus @default(EN_ATTENTE)
  total    Float
  currency String      @default("EUR")

  // Stripe (utilisé par le site vitrine)
  stripeSessionId String?  @unique
  stripePaymentId String?
  email           String?

  // Livraison
  shippingName    String?
  shippingAddress String?
  shippingCity    String?
  shippingZip     String?
  shippingCountry String   @default("FR")
  isDiscreet      Boolean  @default(true)

  items     OrderItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product? @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  title     String  @default("")
  image     String  @default("")

  @@index([orderId])
  @@map("order_items")
}

// ===========================================
// SOCIAL & RÉPUTATION (Axe III)
// ===========================================

model SocialComment {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  dollId  String
  doll    Doll   @relation(fields: [dollId], references: [id], onDelete: Cascade)
  content String
  createdAt DateTime @default(now())

  @@index([dollId])
  @@index([userId])
  @@map("social_comments")
}

model SocialLike {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  dollId String
  doll   Doll   @relation(fields: [dollId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, dollId])
  @@map("social_likes")
}

model AdviceVote {
  id         String @id @default(uuid())
  voterId    String
  voter      User   @relation("VoterAdvice", fields: [voterId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User   @relation("ReceiverAdvice", fields: [receiverId], references: [id], onDelete: Cascade)
  score      Int    // 1-5
  createdAt  DateTime @default(now())

  @@unique([voterId, receiverId])
  @@map("advice_votes")
}

// ===========================================
// SIGNALEMENTS / PROBLÈMES DOLLS
// ===========================================

enum IssueType {
  FISSURE
  ARTICULATION_LACHE
  DECOLORATION
  MOISISSURE
  TACHE
  DECHIRURE
  ODEUR
  USURE
  AUTRE
}

enum BodyZone {
  TETE
  VISAGE
  COU
  EPAULE_GAUCHE
  EPAULE_DROITE
  BRAS_GAUCHE
  BRAS_DROIT
  MAIN_GAUCHE
  MAIN_DROITE
  TORSE_AVANT
  TORSE_ARRIERE
  POITRINE
  VENTRE
  DOS
  BASSIN
  FESSE_GAUCHE
  FESSE_DROITE
  CUISSE_GAUCHE
  CUISSE_DROITE
  GENOU_GAUCHE
  GENOU_DROIT
  JAMBE_GAUCHE
  JAMBE_DROITE
  PIED_GAUCHE
  PIED_DROIT
  AUTRE
}

enum IssueSeverity {
  LEGERE
  MODEREE
  GRAVE
  CRITIQUE
}

enum IssueStatus {
  SIGNALE
  EN_COURS
  REPARE
  SURVEILLE
  IRRECUPERABLE
}

model DollIssue {
  id        String   @id @default(uuid())
  dollId    String
  doll      Doll     @relation(fields: [dollId], references: [id], onDelete: Cascade)

  type       IssueType
  bodyZone   BodyZone
  severity   IssueSeverity  @default(LEGERE)
  status     IssueStatus    @default(SIGNALE)

  title       String
  description String?
  repairPlan  String?       // Ce que l'utilisateur compte faire
  repairNotes String?       // Ce qui a été fait
  repairCost  Float?        // Coût de réparation estimé/réel

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  resolvedAt DateTime?

  @@index([dollId])
  @@index([status])
  @@map("doll_issues")
}

// ===========================================
// CONVERSATIONS IA
// ===========================================

model AiConversation {
  id       String   @id @default(uuid())
  userId   String
  title    String   @default("Nouvelle conversation")
  messages AiMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("ai_conversations")
}

model AiMessage {
  id             String @id @default(uuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String   // "user" or "assistant"
  content        String
  createdAt      DateTime @default(now())

  @@index([conversationId])
  @@map("ai_messages")
}
