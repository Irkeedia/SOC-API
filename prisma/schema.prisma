generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model advice_votes {
  id                                   String   @id @default(uuid())
  voterId                              String
  receiverId                           String
  score                                Int
  createdAt                            DateTime @default(now())
  users_advice_votes_receiverIdTousers users    @relation("advice_votes_receiverIdTousers", fields: [receiverId], references: [id], onDelete: Cascade)
  users_advice_votes_voterIdTousers    users    @relation("advice_votes_voterIdTousers", fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([voterId, receiverId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ai_conversations {
  id          String        @id @default(uuid())
  userId      String
  title       String        @default("Nouvelle conversation")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime @updatedAt
  ai_messages ai_messages[]

  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ai_messages {
  id               String           @id @default(uuid())
  conversationId   String
  role             String
  content          String
  createdAt        DateTime         @default(now())
  ai_conversations ai_conversations @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model appointments {
  id               String            @id @default(uuid())
  userId           String
  dollId           String
  type             AppointmentType
  status           AppointmentStatus @default(DEMANDE)
  scheduledAt      DateTime
  address          String?
  notes            String?
  isStorageService Boolean           @default(false)
  storageStartAt   DateTime?
  storageEndAt     DateTime?
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime @updatedAt
  dolls            dolls             @relation(fields: [dollId], references: [id], onDelete: Cascade)
  users            users             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dollId])
  @@index([scheduledAt])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model doll_issues {
  id          String        @id @default(uuid())
  dollId      String
  type        IssueType
  bodyZone    BodyZone
  severity    IssueSeverity @default(LEGERE)
  status      IssueStatus   @default(SIGNALE)
  title       String
  description String?
  repairPlan  String?
  repairNotes String?
  repairCost  Float?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime @updatedAt
  resolvedAt  DateTime?
  dolls       dolls         @relation(fields: [dollId], references: [id], onDelete: Cascade)

  @@index([dollId])
  @@index([status])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model doll_photos {
  id        String   @id @default(uuid())
  dollId    String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  dolls     dolls    @relation(fields: [dollId], references: [id], onDelete: Cascade)

  @@index([dollId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model dolls {
  id                  String                @id @default(uuid())
  ownerId             String
  fullName            String
  brand               String?
  bodyMaterial        BodyMaterial          @default(TPE)
  headMaterial        HeadMaterial          @default(TPE)
  sizeCm              Float?
  weightKg            Float?
  lastWashedAt        DateTime?
  skinCondition       SkinCondition         @default(IDEALE)
  jointCondition      JointCondition        @default(NEUVE)
  fissureCount        Int                   @default(0)
  maintenanceStage    MaintenanceStage      @default(OPTIMAL)
  degradationLevel    Int                   @default(0)
  statusMessage       String                @default("Tout est en ordre.")
  isPremiumAsset      Boolean               @default(false)
  viewCount           Int                   @default(0)
  likeCount           Int                   @default(0)
  shareCount          Int                   @default(0)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime @updatedAt
  acquisitionDate     DateTime              @default(now())
  bustSize            Float?
  eyeColor            String?
  features            String?
  footSize            Float?
  gender              DollGender            @default(FEMME)
  hairColor           String?
  hairLength          String?
  hairStyle           String?
  hipSize             Float?
  skinTone            String?
  waistSize           Float?
  usage               DollUsage[]           @default([])
  usageDetails        String?
  profilePhotoId      String?
  appointments        appointments[]
  doll_issues         doll_issues[]
  doll_photos         doll_photos[]
  users               users                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  maintenance_records maintenance_records[]
  social_comments     social_comments[]
  social_likes        social_likes[]
  wardrobe_items      wardrobe_items[]

  @@index([ownerId])
}

model email_verification_tokens {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  users     users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model maintenance_records {
  id               String            @id @default(uuid())
  dollId           String
  action           MaintenanceAction
  notes            String?
  performedBy      String?
  performedAt      DateTime          @default(now())
  degradationAfter Int?
  stageAfter       MaintenanceStage?
  dolls            dolls             @relation(fields: [dollId], references: [id], onDelete: Cascade)

  @@index([dollId])
  @@index([performedAt])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model order_items {
  id         String   @id @default(uuid())
  orderId    String
  productId  String
  quantity   Int
  unitPrice  Float
  image      String   @default("")
  title      String   @default("")
  vendorId   String?
  commission Float?
  orders     orders   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  products   products @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([vendorId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model orders {
  id              String        @id @default(uuid())
  userId          String?
  status          OrderStatus   @default(EN_ATTENTE)
  total           Float
  currency        String        @default("EUR")
  shippingAddress String?
  isDiscreet      Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime @updatedAt
  email           String?
  shippingCity    String?
  shippingCountry String        @default("FR")
  shippingName    String?
  shippingZip     String?
  stripePaymentId String?
  stripeSessionId String?       @unique
  order_items     order_items[]
  users           users?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model password_reset_tokens {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  users     users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model products {
  id             String            @id @default(uuid())
  name           String
  description    String?
  price          Float
  currency       String            @default("EUR")
  imageUrl       String?
  category       String
  inStock        Boolean           @default(true)
  stockQty       Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  // ─── Marketplace fields ───
  vendorId       String?
  slug           String?           @unique
  approvalStatus ProductStatus     @default(APPROVED)
  rejectionNote  String?
  commissionRate Float?
  compareAtPrice Float?
  shortDesc      String?
  shippingInfo   String?
  isSOCProduct   Boolean           @default(true)
  featured       Boolean           @default(false)
  sortOrder      Int               @default(0)
  vendor         vendors?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  order_items    order_items[]
  product_images product_images[]
  product_reviews product_reviews[]

  @@index([vendorId])
  @@index([category])
  @@index([approvalStatus])
}

model vendors {
  id              String        @id @default(uuid())
  userId          String        @unique
  businessName    String
  businessEmail   String
  description     String?
  logoUrl         String?
  website         String?
  phone           String?
  address         String?
  city            String?
  country         String        @default("FR")
  status          VendorStatus  @default(PENDING)
  commissionRate  Float         @default(15)
  totalSales      Float         @default(0)
  totalPaid       Float         @default(0)
  approvedAt      DateTime?
  rejectedNote    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            users         @relation(fields: [userId], references: [id], onDelete: Cascade)
  products        products[]
  payouts         vendor_payouts[]

  @@index([status])
}

model product_images {
  id        String   @id @default(uuid())
  productId String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   products @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model product_reviews {
  id        String   @id @default(uuid())
  productId String
  userId    String
  rating    Int
  title     String?
  comment   String?
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   products @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId])
}

model vendor_payouts {
  id           String       @id @default(uuid())
  vendorId     String
  amount       Float
  currency     String       @default("EUR")
  status       PayoutStatus @default(PENDING)
  periodStart  DateTime
  periodEnd    DateTime
  orderCount   Int          @default(0)
  commission   Float
  notes        String?
  paidAt       DateTime?
  createdAt    DateTime     @default(now())
  vendor       vendors      @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([status])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model refresh_tokens {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  users     users     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model social_comments {
  id        String   @id @default(uuid())
  userId    String
  dollId    String
  content   String
  createdAt DateTime @default(now())
  dolls     dolls    @relation(fields: [dollId], references: [id], onDelete: Cascade)
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dollId])
  @@index([userId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model social_likes {
  id        String   @id @default(uuid())
  userId    String
  dollId    String
  createdAt DateTime @default(now())
  dolls     dolls    @relation(fields: [dollId], references: [id], onDelete: Cascade)
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dollId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id                                          String                      @id @default(uuid())
  email                                       String                      @unique
  passwordHash                                String
  displayName                                 String                      @default("")
  profileVisibility                           ProfileVisibility           @default(PRIVATE)
  subscriptionTier                            SubscriptionTier            @default(FREE)
  avatarUrl                                   String?
  dailyCommentCount                           Int                         @default(0)
  dailyCommentReset                           DateTime                    @default(now())
  adviceScore                                 Int                         @default(0)
  adviceVotes                                 Int                         @default(0)
  reputationScore                             Float                       @default(0)
  darkMode                                    Boolean                     @default(false)
  createdAt                                   DateTime                    @default(now())
  updatedAt                                   DateTime @updatedAt
  address                                     String                      @default("")
  firstName                                   String                      @default("")
  lastName                                    String                      @default("")
  phone                                       String                      @default("")
  aiMessageCount                              Int                         @default(0)
  aiMessageResetAt                            DateTime                    @default(now())
  role                                        Role                        @default(USER)
  emailVerified                               Boolean                     @default(false)
  advice_votes_advice_votes_receiverIdTousers advice_votes[]              @relation("advice_votes_receiverIdTousers")
  advice_votes_advice_votes_voterIdTousers    advice_votes[]              @relation("advice_votes_voterIdTousers")
  appointments                                appointments[]
  dolls                                       dolls[]
  email_verification_tokens                   email_verification_tokens[]
  orders                                      orders[]
  password_reset_tokens                       password_reset_tokens[]
  refresh_tokens                              refresh_tokens[]
  social_comments                              social_comments[]
  social_likes                                  social_likes[]
  vendor                                        vendors?
  product_reviews                               product_reviews[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model wardrobe_items {
  id         String   @id @default(uuid())
  dollId     String
  name       String
  category   String?
  color      String?
  material   String?
  length     String?
  brand      String?
  notes      String?
  imageUrl   String?
  acquiredAt DateTime @default(now())
  dolls      dolls    @relation(fields: [dollId], references: [id], onDelete: Cascade)

  @@index([dollId])
}

